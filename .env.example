# Copia este archivo a .env y completa los valores reales.
# .env NO se sube a git (ver .gitignore); .env.example sí, como plantilla.

# Genera una clave nueva y única para cada entorno (nunca reutilices esta):
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-secreta-unica

DEBUG=True

# Lista separada por comas, ej: midominio.com,www.midominio.com
ALLOWED_HOSTS=

# API key de Elsevier/Scopus, para automatizar la Importancia Sugerida (IS)
# de los factores del catálogo con evidencia bibliográfica (catalog.services).
# Si se deja vacío, el sistema usa Factor.importancia_base tal cual.
SCOPUS_API_KEY=
